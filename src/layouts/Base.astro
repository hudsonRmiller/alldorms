---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';
const {
  title = 'AllDorms — the college move-in guide for the people doing the packing',
  description = 'Move-in, sorted. Real packing lists, housing answers, and where-to-stay guides for 12 universities — built for the parents getting their child to campus.',
  bodyClass = '',
  theme = undefined,   // optional CSS-variable overrides (per-school colour theme)
} = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <link rel="icon" type="image/png" href="/logo.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Piazzolla:opsz,wght@8..30,500;8..30,600;8..30,700&family=Literata:ital,opsz,wght@0,7..72,400;0,7..72,600;0,7..72,700;1,7..72,400&family=Schibsted+Grotesk:wght@400;500;600;700&family=Spline+Sans+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body class={bodyClass} style={theme}>
  <header class="sitehead">
    <div class="wrap sitehead-in">
      <a href="/" class="brand">
        <img class="mark" src="/logo.png" alt="AllDorms" width="34" height="34" />
        <span class="word">All<b>Dorms</b></span>
      </a>
      <nav class="headnav">
        <a href="/#schools">Schools</a>
        <a href="/#how">How it works</a>
        <a href="/#schools" class="headnav-cta">Find your school</a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="sitefoot">
    <div class="wrap">
      <div class="foot-grid">
        <div>
          <div class="foot-mark">All<b>Dorms</b></div>
          <p class="muted">Made by college students who've done the move, for the parents about to do it. Real lists, local rules, and the answers the generic checklists never had — for 12 schools, with more on the way.</p>
        </div>
        <div>
          <h4>The guides</h4>
          <ul>
            <li><a href="/#schools">All 12 schools</a></li>
            <li><a href="/#how">What's inside</a></li>
          </ul>
        </div>
        <div>
          <h4>One quick note</h4>
          <p class="muted">We pull from each school's official housing pages, but always double-check the specifics there before you buy — policies and renovations change every year. AllDorms is an independent guide, not affiliated with any university.</p>
          <p class="muted">As an Amazon Associate, AllDorms earns from qualifying purchases. The "Shop" links go to Amazon and may earn us a small commission — at no extra cost to you.</p>
        </div>
      </div>
    </div>
  </footer>

  <script is:inline>
    // homepage header: transparent over the hero, solid once you scroll
    (function () {
      var head = document.querySelector('.sitehead');
      if (!head || !document.body.classList.contains('home')) return;
      var onScroll = function () { head.classList.toggle('solid', window.scrollY > 40); };
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });
    })();
  </script>
  <Analytics />
</body>
</html>
