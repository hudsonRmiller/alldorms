---
import fs from 'node:fs';
import path from 'node:path';
import Base from '../layouts/Base.astro';
import Postcard from '../components/Postcard.astro';
import { SCHOOLS, schoolSections, cityShort } from '../lib/site.js';

// per-school crop focal point (object-position) — only needed where the
// default center crop would cut the subject (e.g. UT's tall tower)
const FOCUS = { utexas: '50% 26%' };
const photoDir = path.join(process.cwd(), 'public', 'schools');

const schools = SCHOOLS.map(s => {
  const photo = fs.existsSync(path.join(photoDir, `${s.slug}.jpg`)) ? `/schools/${s.slug}.jpg` : null;
  return {
    ...s,
    count: schoolSections(s).length,
    cityShort: cityShort(s),
    photo,
    focus: FOCUS[s.slug] || null,
  };
});
const guideSections = ['Weather & clothing','What’s allowed','Housing & roommates','Where you’ll live','Packing checklist','Move-in logistics','Town & hotspots','Where to stay','School gear','Links & contacts'];

const HERO = '/hero.jpg';
const READING = 'https://images.unsplash.com/photo-1564981797816-1043664bf78d?w=1400&q=80&auto=format&fit=crop';
---
<Base bodyClass="home">
  {/* hero */}
  <section class="lhero">
    <img class="lhero-img" src={HERO} alt="A university quad in the warm light of late summer" fetchpriority="high" />
    <div class="lhero-scrim"></div>
    <div class="wrap lhero-in">
      <div class="lhero-text">
        <span class="kick light">The college move-in almanac</span>
        <h1>Pack like you already<br />know the place.</h1>
        <p class="lhero-sub">
          Every packing list online was written for nowhere in particular. AllDorms is written
          for <em>your</em> school — the real rules, the real local weather, and a checklist sized
          for the room your child is actually moving into.
        </p>
        <div class="lhero-cta">
          <a href="#schools" class="btn btn-gold">Find your school</a>
          <a href="#how" class="btn btn-ghost-light">See what's inside</a>
        </div>
      </div>
    </div>
    <a href="#how" class="lhero-scroll" aria-label="Scroll down">
      <span class="lhero-scroll-line"></span>
    </a>
  </section>

  {/* what's inside */}
  <section id="how" class="how">
    <div class="wrap">
      <div class="how-head">
        <span class="kick">The one thing generic lists get wrong</span>
        <h2>"Check with your school for what's allowed." So we did — for all of them.</h2>
        <p>Every generic packing list ends with that one line. So we did the checking — for all twelve schools. Knowing the dorm is Twin XL, the winter is real, and the air fryer stays home is what turns a stressful drop-off into an easy one.</p>
      </div>

      <div class="how-feature">
        <figure class="how-photo">
          <img src={READING} alt="A sunlit university reading room" loading="lazy" />
          <figcaption>Built from each school's own housing pages — not a generic template.</figcaption>
        </figure>
        <div class="how-pillars">
          <div class="how-item">
            <span class="how-num">Rules</span>
            <h3>What your room will actually take.</h3>
            <p>Fridge cubic-feet limits, microwave wattages, whether there's air conditioning, and the appliances each housing office turns away at the door — pulled from the source, school by school.</p>
          </div>
          <div class="how-item">
            <span class="how-num">Weather</span>
            <h3>Dressed for the right zip code.</h3>
            <p>Month by month, what to wear — from a 110° Tempe move-in to a sub-zero Minnesota January to Seattle's long gray drizzle. No parka for Florida.</p>
          </div>
          <div class="how-item">
            <span class="how-num">The list</span>
            <h3>A checklist you'll actually finish.</h3>
            <p>Categorized, room-sized, check-as-you-pack, with a progress bar — and a clothing section that changes with the climate, not someone else's.</p>
          </div>
        </div>
      </div>

      <div class="how-index">
        <span class="kick plain">Every school's guide includes</span>
        <ol class="guide-index">
          {guideSections.map((g, i) => (
            <li><span class="gi-n">{String(i + 1).padStart(2, '0')}</span>{g}</li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  {/* schools directory */}
  <section id="schools" class="schools">
    <div class="wrap">
      <div class="schools-head">
        <span class="kick">Twelve editions</span>
        <h2>Pick your school</h2>
        <p>Each one built from that school's official housing pages. Select your child's university to open theirs.</p>
      </div>
      <div class="school-grid">
        {schools.map(s => (
          <a href={`/${s.slug}/`} class="scard" style={`--accent:${s.accent}` + (s.focus ? `;--focus:${s.focus}` : '')}>
            {s.photo
              ? <img class="scard-photo" src={s.photo} alt={`${s.name} campus`} loading="lazy" />
              : <div class="scard-art"><Postcard school={s} /></div>}
            <span class="scard-bar"></span>
            <div class="scard-scrim"></div>
            <div class="scard-meta">
              <span class="scard-name">{s.name}</span>
              <span class="scard-city">{s.cityShort}</span>
            </div>
            <span class="scard-go" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  /* ---------- hero ---------- */
  .lhero {
    position: relative; min-height: 94vh; display: flex; align-items: flex-end;
    overflow: hidden; background: var(--navy-deep);
  }
  .lhero-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .lhero-scrim {
    position: absolute; inset: 0;
    background:
      linear-gradient(180deg, rgba(18,28,52,.62) 0%, rgba(18,28,52,.12) 26%, rgba(18,28,52,.30) 60%, rgba(15,23,44,.86) 100%),
      linear-gradient(90deg, rgba(15,23,44,.55) 0%, rgba(15,23,44,0) 60%);
  }
  .lhero-in { position: relative; width: 100%; padding: 120px 28px 9vh; }
  .lhero-text { max-width: 46ch; }
  .lhero-text .kick.light { color: var(--gold-soft); margin-bottom: 1.1rem; }
  .lhero-text h1 {
    color: #fff; font-size: clamp(2.7rem, 6.4vw, 5rem); line-height: 1.02;
    letter-spacing: -.022em; margin-bottom: 1rem;
    text-shadow: 0 2px 30px rgba(0,0,0,.3);
  }
  .lhero-sub {
    font-size: clamp(1.08rem, 1.5vw, 1.3rem); line-height: 1.55; color: #e8eaf1;
    max-width: 52ch; margin-bottom: 1.9rem; text-shadow: 0 1px 16px rgba(0,0,0,.35);
  }
  .lhero-sub em { color: #fff; font-style: italic; }
  .lhero-cta { display: flex; gap: 12px; flex-wrap: wrap; }
  .lhero-scroll {
    position: absolute; left: 50%; bottom: 26px; transform: translateX(-50%);
    width: 26px; height: 44px; border: 1.5px solid rgba(255,255,255,.5); border-radius: 14px;
    display: grid; place-items: start center; padding-top: 7px;
  }
  .lhero-scroll-line { width: 3px; height: 9px; border-radius: 2px; background: rgba(255,255,255,.85); animation: scrolldot 1.7s ease-in-out infinite; }
  @keyframes scrolldot { 0%,100% { transform: translateY(0); opacity: .4; } 50% { transform: translateY(9px); opacity: 1; } }

  /* ---------- what's inside ---------- */
  .how { padding: 92px 0 84px; background: var(--paper-2); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .how-head { max-width: 34ch; margin-bottom: 2.8rem; }
  .how-head .kick { margin-bottom: .8rem; }
  .how-head h2 { font-size: clamp(1.9rem, 3.6vw, 2.95rem); line-height: 1.1; margin-bottom: .55rem; max-width: 20ch; }
  .how-head p { font-size: 1.14rem; color: var(--ink-soft); line-height: 1.58; max-width: 60ch; }

  .how-feature { display: grid; grid-template-columns: 1.05fr 1fr; gap: 48px; align-items: center; margin-bottom: 3.4rem; }
  .how-photo { margin: 0; position: relative; border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-soft); }
  .how-photo img { display: block; width: 100%; height: 100%; max-height: 460px; object-fit: cover; }
  .how-photo figcaption {
    position: absolute; left: 0; right: 0; bottom: 0; padding: 1.6rem 1.4rem .9rem;
    font-family: var(--sans); font-size: .82rem; color: #fff; line-height: 1.4;
    background: linear-gradient(180deg, rgba(15,23,44,0), rgba(15,23,44,.78));
  }
  .how-pillars { display: flex; flex-direction: column; gap: 1.5rem; }
  .how-item { padding-left: 1.1rem; border-left: 3px solid var(--gold); }
  .how-num { font-family: var(--sans); font-size: .74rem; font-weight: 700; letter-spacing: .04em; text-transform: uppercase; color: var(--gold-deep); }
  .how-item h3 { font-size: 1.32rem; margin: .25rem 0 .4rem; }
  .how-item p { font-size: 1rem; line-height: 1.56; color: var(--ink-soft); margin: 0; }

  .how-index { border-top: 1px solid var(--line-2); padding-top: 1.8rem; }
  .how-index .kick { margin-bottom: 1.1rem; }
  .guide-index { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: repeat(2, 1fr); gap: 0 48px; }
  .guide-index li { display: flex; align-items: baseline; gap: .8rem; padding: .55rem 0; border-top: 1px solid var(--line); font-size: 1.08rem; color: var(--navy); font-family: var(--display); font-weight: 480; }
  .guide-index li:nth-child(1), .guide-index li:nth-child(2) { border-top: none; }
  .gi-n { font-family: var(--mono); font-size: .68rem; color: var(--gold-deep); flex: none; }

  /* ---------- schools grid ---------- */
  .schools { padding: 88px 0 100px; }
  .schools-head { margin-bottom: 2.4rem; max-width: 60ch; }
  .schools-head .kick { margin-bottom: .7rem; }
  .schools-head h2 { font-size: clamp(2rem, 3.8vw, 3rem); margin-bottom: .4rem; }
  .schools-head p { font-size: 1.12rem; color: var(--ink-soft); }

  .school-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 22px; }
  .scard {
    position: relative; display: block; aspect-ratio: 5 / 4; border-radius: var(--radius-lg);
    overflow: hidden; text-decoration: none; background: var(--navy);
    box-shadow: var(--shadow-card);
    transition: transform .22s ease, box-shadow .22s ease;
  }
  .scard-art { position: absolute; inset: 0; transition: transform .5s ease; }
  .scard-photo { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: var(--focus, 50% 42%); transition: transform .5s ease; }
  .scard:hover .scard-photo { transform: scale(1.06); }
  .scard-bar { position: absolute; top: 0; left: 0; right: 0; height: 4px; background: var(--accent); z-index: 3; }
  .scard-scrim { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(15,23,44,0) 38%, rgba(13,20,38,.74) 100%); z-index: 2; }
  .scard-meta { position: absolute; left: 1.05rem; bottom: .95rem; z-index: 3; display: flex; flex-direction: column; }
  .scard-name { font-family: var(--display); font-weight: 600; font-size: 1.32rem; color: #fff; line-height: 1.12; text-shadow: 0 1px 14px rgba(0,0,0,.4); }
  .scard-city { font-family: var(--sans); font-size: .76rem; font-weight: 500; letter-spacing: .02em; color: rgba(255,255,255,.82); margin-top: 3px; }
  .scard-go {
    position: absolute; top: .85rem; right: .9rem; z-index: 3;
    width: 32px; height: 32px; border-radius: 50%; display: grid; place-items: center;
    background: rgba(255,255,255,.16); color: #fff; font-size: 1.05rem;
    backdrop-filter: blur(4px); opacity: 0; transform: translateY(-4px);
    transition: opacity .22s ease, transform .22s ease;
  }
  .scard:hover { transform: translateY(-5px); box-shadow: 0 26px 46px -22px rgba(28,40,70,.6); }
  .scard:hover .scard-art { transform: scale(1.06); }
  .scard:hover .scard-go { opacity: 1; transform: translateY(0); }

  @media (max-width: 1040px) { .school-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 860px) {
    .how-feature { grid-template-columns: 1fr; gap: 28px; }
    .how-photo img { max-height: 320px; }
    .school-grid { grid-template-columns: repeat(2, 1fr); gap: 16px; }
    .guide-index { grid-template-columns: 1fr; }
    .guide-index li:nth-child(2) { border-top: 1px solid var(--line); }
  }
  @media (max-width: 520px) {
    .school-grid { grid-template-columns: 1fr; }
    .lhero { min-height: 88vh; }
  }
</style>
